{
  "name": "ctx-share",
  "version": "0.4.0",
  "description": "Share AI coding context between Codex and Claude Code",
  "keywords": [
    "ai",
    "cli",
    "claude-code",
    "codex",
    "context",
    "handoff",
    "llm"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "ctx": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run test && npm run build"
  },
  "dependencies": {
    "clipboardy": "^4.0.0",
    "commander": "^12.1.0",
    "execa": "^9.6.0",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.13.14",
    "@types/prompts": "^2.4.9",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
